{
  "server": {
    "host": "0.0.0.0",
    "port": 8814,
    "name": "fortigate-mcp-server",
    "version": "1.0.0"
  },
  "auth": {
    "require_auth": false,
    "_comment_auth": "Set require_auth to true and add keys to api_tokens to lock down access.",
    "_comment_how": "Clients send: Authorization: Bearer <key>  OR  X-API-Key: <key>",
    "_comment_generate": "Generate a key with: openssl rand -hex 32",
    "api_tokens": [],
    "allowed_origins": [
      "*"
    ]
  },
  "logging": {
    "level": "INFO",
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s",
    "_comment_file": "Docker: /app/logs/mcp_fortigate.log  |  Bare metal: /var/log/mcp_fortigate.log",
    "file": "/var/log/mcp_fortigate.log",
    "console": true
  },
  "rate_limiting": {
    "enabled": true,
    "max_requests_per_minute": 60,
    "burst_size": 10
  },
  "fortigate": {
    "devices": {}
  },
  "fortimanager": {
    "fortimanagers": {}
  }
}
